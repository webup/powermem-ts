# PowerMem TS SDK 配置
# 复制为 .env 并填写实际值
#
# 纯 TypeScript 实现，无需 Python 环境。
# 需要配置 LLM 和 Embedding 提供商。

# =============================================================================
# LLM 配置（用于 infer 功能，即智能记忆提取）
# =============================================================================
# 支持：qwen, openai, siliconflow, deepseek, anthropic, ollama
LLM_PROVIDER=qwen
LLM_API_KEY=your_api_key_here
LLM_MODEL=qwen-plus

QWEN_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_LLM_BASE_URL=https://api.openai.com/v1
SILICONFLOW_LLM_BASE_URL=https://api.siliconflow.cn/v1
OLLAMA_LLM_BASE_URL=
DEEPSEEK_LLM_BASE_URL=https://api.deepseek.com
ANTHROPIC_LLM_BASE_URL=https://api.anthropic.com

# =============================================================================
# Embedding 配置（必填）
# =============================================================================
# 支持：qwen, openai, siliconflow, deepseek, ollama
EMBEDDING_PROVIDER=qwen
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMS=1536
